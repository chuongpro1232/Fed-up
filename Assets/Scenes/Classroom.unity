  m_GameObject: {fileID: 270822552}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 95abcb000f01b2244809125ae14af201, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  speakerPoint: {fileID: 1432890304}
  speakerName: Player
  dialogueLines:
  - Now the judgement day had come. I had prepared really carefully.
  - 'I deleted my precious CS2 for this test. I must get HD not matter what. '
  - Hours of studying this chemistry, I started to feels a little bit fed-up with
    this.
  - I wonder if I fail this can I have a career in Esport ?
  playerTransform: {fileID: 489317897}
  playerMovement: {fileID: 489317892}
  walkWaypoint: {fileID: 1923373302}
  walkSpeed: 2
  teacherTransform: {fileID: 1305000404}
  cameraFollow: {fileID: 56944479}
  teacherZoomLevel: 3
  zoomSpeed: 2
  teacherSpeakerName: Teacher
  teacherDialogueLines:
  - 'Today we have a test as you already know. '
  - 'I hope you all had done your homework and looked the materials I gave you. '
  - Remember that this result will affect heavily on your future career path.
  - Please go to the blackboard at the wall to take the test.
  blackboardTrigger: {fileID: 1668797058}
  postMinigameTeacherLines:
  - "I can\u2019t say I\u2019m surprised."
  - "You can leave the room, but you can\u2019t leave your incompetence behind."
  exitClassWaypoint: {fileID: 414420199}
  nextSceneName: Net
